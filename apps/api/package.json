{
  "name": "@lumera/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "format": "prettier --check \"src/**/*.ts\"",
