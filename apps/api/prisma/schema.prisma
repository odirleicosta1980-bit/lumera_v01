generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationType {
  LUMERA
  CLIENT
}

enum MembershipScopeType {
  ORGANIZATION
  CLIENT_COMPANY
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum LicitacaoVisibility {
  INTERNAL_ONLY
  SHARED_WITH_CLIENT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum AttachmentEntityType {
  LICITACAO
  EMPENHO
  TAREFA
  COMENTARIO
}

enum AttachmentCategory {
  GENERAL
  EDITAL_BASE
  DOCUMENTO_EMPENHO
  BOLETO
  COMPROVANTE_PAGAMENTO
  OUTRO
}

enum ClientCompanyDocumentGroup {
  HABILITACAO_JURIDICA
  REGULARIDADE_FISCAL_TRABALHISTA
  QUALIFICACAO_ECONOMICO_FINANCEIRA
  CADASTRO_SISTEMA_ELETRONICO
  OUTROS_DOCUMENTOS
}

enum ClientCompanyDocumentStatus {
  PENDENTE
  ENVIADO
  VALIDO
  VENCE_EM_BREVE
  VENCIDO
  NAO_APLICAVEL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum LicitacaoItemStatus {
  PENDENTE
  EM_PRECIFICACAO
  PRECIFICADO
  DESCARTADO
}

enum CobrancaModelo {
  FIXO
  EXITO
  FIXO_MAIS_EXITO
  PERSONALIZADO
}

enum FormaPagamento {
  PIX
  BOLETO
  TRANSFERENCIA
  FATURAMENTO
  OUTRO
}

enum FinanceiroStatus {
  NAO_APLICAVEL
  PENDENTE
  PARCIAL
  PAGO
  ATRASADO
}

enum EntityType {
  LICITACAO
  TAREFA
  COMENTARIO
  ANEXO
  USUARIO
  ORGANIZATION
  CLIENT_COMPANY
  ETAPA
}

model Organization {
  id              String          @id @default(uuid())
  type            OrganizationType
  legalName       String
  tradeName       String?
  slug            String          @unique
  taxId           String?         @unique
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  clientCompanies ClientCompany[]
  memberships     Membership[]
  licitacoes      Licitacao[]
  taskTemplates   TaskTemplate[]
  etapas          EtapaLicitacao[]
  clientCompanyDocumentTypes ClientCompanyDocumentType[]
  clientCompanyDocuments     ClientCompanyDocument[]
  activityLogs    ActivityLog[]
  auditLogs       AuditLog[]
}

model ClientCompany {
  id                 String        @id @default(uuid())
  organizationId     String
  legalName          String
  tradeName          String?
  segmento           String?
  taxId              String?       @unique
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  organization       Organization  @relation(fields: [organizationId], references: [id])
  memberships        Membership[]
  financialRule      ClientCompanyFinancialRule?
  licitacoes         Licitacao[]
  documents          ClientCompanyDocument[]
  tags               Tag[]
  kanbanPreferences  KanbanPreference[]
}

model User {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String                  @unique
  passwordHash           String?
  isActive               Boolean                 @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  memberships            Membership[]
  responsavelEm          LicitacaoResponsavel[]
  tarefas                TarefaResponsavel[]
  comentarios            Comentario[]
  notifications          Notification[]
  taskTemplates          TaskTemplate[]
  financeiroRateios      LicitacaoFinanceiroRateio[]
  checkedCompanyDocuments ClientCompanyDocument[]
  auditLogs              AuditLog[]              @relation("AuditActor")
}

model Role {
  id             String            @id @default(uuid())
  code           String            @unique
  name           String
  description    String?
  isSystem       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  memberships  Membership[]
  permissions    RolePermission[]
}

model Permission {
  id             String            @id @default(uuid())
  code           String            @unique
  name           String
  description    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  roles          RolePermission[]
}

model RolePermission {
  id             String            @id @default(uuid())
  roleId         String
  permissionId   String
  effect         PermissionEffect  @default(ALLOW)
  createdAt      DateTime          @default(now())
  role           Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission     Permission        @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Membership {
  id                String                @id @default(uuid())
  userId            String
  organizationId    String
  roleId            String
  scopeType         MembershipScopeType   @default(ORGANIZATION)
  clientCompanyId   String?
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User                  @relation(fields: [userId], references: [id])
  organization      Organization          @relation(fields: [organizationId], references: [id])
  role              Role                  @relation(fields: [roleId], references: [id])
  clientCompany     ClientCompany?        @relation(fields: [clientCompanyId], references: [id])

  @@index([organizationId, scopeType, clientCompanyId])
}

model EtapaLicitacao {
  id                String        @id @default(uuid())
  organizationId    String
  name              String
  code              String
  color             String?
  sortOrder         Int
  isActive          Boolean       @default(true)
  isSystem          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization          @relation(fields: [organizationId], references: [id])
  licitacoes        Licitacao[]

  @@unique([organizationId, code])
  @@unique([organizationId, sortOrder])
}

model ClientCompanyFinancialRule {
  id                  String          @id @default(uuid())
  clientCompanyId     String          @unique
  chargingModel       CobrancaModelo  @default(EXITO)
  percentualLumera    Decimal?        @db.Decimal(7, 4)
  valorFixoLumera     Decimal?        @db.Decimal(14, 2)
  formaPagamento      FormaPagamento?
  observacoes         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  clientCompany       ClientCompany   @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
}

model ClientCompanyDocumentType {
  id                  String                     @id @default(uuid())
  organizationId      String
  code                String
  name                String
  group               ClientCompanyDocumentGroup
  description         String?
  requiresExpiration  Boolean                    @default(false)
  warningDays         Int                        @default(30)
  isRequired          Boolean                    @default(true)
  isSystem            Boolean                    @default(false)
  sortOrder           Int                        @default(0)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  organization        Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents           ClientCompanyDocument[]

  @@unique([organizationId, code])
  @@index([organizationId, sortOrder])
}

model ClientCompanyDocument {
  id                  String                      @id @default(uuid())
  organizationId      String
  clientCompanyId     String
  documentTypeId      String
  status              ClientCompanyDocumentStatus @default(PENDENTE)
  issueDate           DateTime?
  expirationDate      DateTime?
  deliveredAt         DateTime?
  lastValidatedAt     DateTime?
  checkedByUserId     String?
  observations        String?
  fileName            String?
  originalFileName    String?
  mimeType            String?
  sizeBytes           BigInt?
  storageKey          String?                     @unique
  checksumSha256      String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  organization        Organization                @relation(fields: [organizationId], references: [id])
  clientCompany       ClientCompany               @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  documentType        ClientCompanyDocumentType   @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  checkedByUser       User?                       @relation(fields: [checkedByUserId], references: [id], onDelete: SetNull)

  @@unique([clientCompanyId, documentTypeId])
  @@index([organizationId, status])
  @@index([clientCompanyId, status])
  @@index([clientCompanyId, expirationDate])
}

model Licitacao {
  id                 String                  @id @default(uuid())
  organizationId     String
  clientCompanyId    String
  etapaId            String
  titulo             String
  descricao          String?
  numeroProcesso     String?
  portalOrigem       String?
  orgao              String?
  modalidade         String?
  valorEstimado      Decimal?                @db.Decimal(14, 2)
  dataSessao         DateTime?
  sortOrder          Int                     @default(0)
  visibility         LicitacaoVisibility     @default(SHARED_WITH_CLIENT)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  organization       Organization            @relation(fields: [organizationId], references: [id])
  clientCompany      ClientCompany           @relation(fields: [clientCompanyId], references: [id])
  etapa              EtapaLicitacao          @relation(fields: [etapaId], references: [id])
  financeiro         LicitacaoFinanceiro?
  empenhos           LicitacaoEmpenho[]
  responsaveis       LicitacaoResponsavel[]
  itens              LicitacaoItem[]
  tarefas            Tarefa[]
  comentarios        Comentario[]
  anexos             Anexo[]
  tags               LicitacaoTag[]
  activities         ActivityLog[]
  audits             AuditLog[]

  @@index([organizationId, etapaId, sortOrder])
  @@index([clientCompanyId, etapaId])
}

model LicitacaoFinanceiro {
  id                    String                       @id @default(uuid())
  licitacaoId           String                       @unique
  valorEstimadoEdital   Decimal?                     @db.Decimal(14, 2)
  valorPropostaEmpresa  Decimal?                     @db.Decimal(14, 2)
  valorHomologado       Decimal?                     @db.Decimal(14, 2)
  chargingModel         CobrancaModelo              @default(EXITO)
  percentualLumera      Decimal?                     @db.Decimal(7, 4)
  valorFixoLumera       Decimal?                     @db.Decimal(14, 2)
  valorReceitaLumera    Decimal?                     @db.Decimal(14, 2)
  formaPagamento        FormaPagamento?
  statusFinanceiro      FinanceiroStatus            @default(PENDENTE)
  vencimento            DateTime?
  observacoes           String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  licitacao             Licitacao                    @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  allocations           LicitacaoFinanceiroRateio[]
}

model LicitacaoFinanceiroRateio {
  id                    String                @id @default(uuid())
  licitacaoFinanceiroId String
  userId                String?
  label                 String
  percentual            Decimal?              @db.Decimal(7, 4)
  valor                 Decimal?              @db.Decimal(14, 2)
  sortOrder             Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  financeiro            LicitacaoFinanceiro   @relation(fields: [licitacaoFinanceiroId], references: [id], onDelete: Cascade)
  user                  User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([licitacaoFinanceiroId, sortOrder])
}

model LicitacaoEmpenho {
  id                    String      @id @default(uuid())
  licitacaoId           String
  codigoEmpenho         String
  valor                 Decimal     @db.Decimal(14, 2)
  dataEmpenho           DateTime?
  dataPagamentoEmpenho  DateTime?
  dataGeracaoBoleto     DateTime?
  dataPagamentoBoleto   DateTime?
  observacoes           String?
  sortOrder             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  licitacao             Licitacao   @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  anexos                Anexo[]

  @@index([licitacaoId, sortOrder])
  @@index([licitacaoId, dataEmpenho])
}
model LicitacaoResponsavel {
  id              String      @id @default(uuid())
  licitacaoId     String
  userId          String
  isPrimary       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  licitacao       Licitacao   @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id])

  @@unique([licitacaoId, userId])
}

model LicitacaoItem {
  id                 String               @id @default(uuid())
  licitacaoId        String
  numeroItem         String?
  numeroLote         String?
  descricao          String
  unidade            String?
  quantidade         Decimal?             @db.Decimal(14, 4)
  valorReferencia    Decimal?             @db.Decimal(14, 2)
  valorProposto      Decimal?             @db.Decimal(14, 2)
  marcaModelo        String?
  observacoes        String?
  status             LicitacaoItemStatus  @default(PENDENTE)
  sortOrder          Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  licitacao          Licitacao            @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)

  @@index([licitacaoId, sortOrder])
  @@index([licitacaoId, status])
}

model Tarefa {
  id                 String               @id @default(uuid())
  licitacaoId        String
  templateId         String?
  title              String
  description        String?
  status             TaskStatus           @default(TODO)
  dueDate            DateTime?
  createdByUserId    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  licitacao          Licitacao            @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  template           TaskTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  responsaveis       TarefaResponsavel[]
  comentarios        Comentario[]
}

model TaskTemplate {
  id                 String       @id @default(uuid())
  organizationId     String
  title              String
  description        String?
  defaultDueDays     Int?
  createdByUserId    String?
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser      User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  tarefas            Tarefa[]

  @@index([organizationId, isActive])
  @@unique([organizationId, title])
}

model TarefaResponsavel {
  id              String      @id @default(uuid())
  tarefaId        String
  userId          String
  createdAt       DateTime    @default(now())
  tarefa          Tarefa      @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id])

  @@unique([tarefaId, userId])
}

model Comentario {
  id                 String      @id @default(uuid())
  licitacaoId        String?
  tarefaId           String?
  userId             String
  body               String
  isInternal         Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  licitacao          Licitacao?  @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  tarefa             Tarefa?     @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  user               User        @relation(fields: [userId], references: [id])
  anexos             Anexo[]
}

model Anexo {
  id                 String                @id @default(uuid())
  organizationId     String
  licitacaoId        String?
  comentarioId       String?
  empenhoId          String?
  uploadedByUserId   String?
  entityType         AttachmentEntityType
  category           AttachmentCategory    @default(GENERAL)
  fileName           String
  originalFileName   String
  mimeType           String
  sizeBytes          BigInt
  storageKey         String                @unique
  checksumSha256     String?
  createdAt          DateTime              @default(now())
  licitacao          Licitacao?            @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  comentario         Comentario?           @relation(fields: [comentarioId], references: [id], onDelete: Cascade)
  empenho            LicitacaoEmpenho?     @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
}

model Tag {
  id                 String          @id @default(uuid())
  clientCompanyId    String?
  name               String
  color              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  clientCompany      ClientCompany?  @relation(fields: [clientCompanyId], references: [id])
  licitacoes         LicitacaoTag[]

  @@unique([clientCompanyId, name])
}

model LicitacaoTag {
  id             String      @id @default(uuid())
  licitacaoId    String
  tagId          String
  licitacao      Licitacao   @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  tag            Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([licitacaoId, tagId])
}

model Notification {
  id                 String               @id @default(uuid())
  userId             String
  title              String
  body               String
  channel            NotificationChannel  @default(IN_APP)
  status             NotificationStatus   @default(PENDING)
  actionUrl          String?
  createdAt          DateTime             @default(now())
  sentAt             DateTime?
  readAt             DateTime?
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id                 String       @id @default(uuid())
  organizationId     String
  licitacaoId        String?
  entityType         EntityType
  entityId           String
  action             String
  description        String?
  metadata           Json?
  createdAt          DateTime     @default(now())
  organization      Organization          @relation(fields: [organizationId], references: [id])
  licitacao          Licitacao?   @relation(fields: [licitacaoId], references: [id])
}

model AuditLog {
  id                 String       @id @default(uuid())
  organizationId     String
  licitacaoId        String?
  actorUserId        String?
  entityType         EntityType
  entityId           String
  action             String
  oldData            Json?
  newData            Json?
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime     @default(now())
  organization      Organization          @relation(fields: [organizationId], references: [id])
  licitacao          Licitacao?   @relation(fields: [licitacaoId], references: [id])
  actorUser          User?        @relation("AuditActor", fields: [actorUserId], references: [id])
}

model KanbanPreference {
  id                 String         @id @default(uuid())
  clientCompanyId    String
  userId             String?
  collapsedColumns   Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  clientCompany      ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@index([clientCompanyId])
}

