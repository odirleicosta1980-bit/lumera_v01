{
  "name": "lumera",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "db:generate": "pnpm --filter @lumera/api prisma:generate",
    "db:migrate": "pnpm --filter @lumera/api prisma:migrate",
    "db:seed": "pnpm --filter @lumera/api prisma:seed"
  }
}
